{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "@wtsreact/typescript-config/next.json",
  "compilerOptions": {
    "declaration": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/mui-theme/*": ["../../packages/mui-theme/src/*"],
      "@/ui/*": ["../../packages/shared-ui/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", ".next/types/**/*.ts", "../../packages/mui-theme/src/types.ts"],
  "exclude": ["node_modules"],
  "typeRoots": ["./node_modules/@types"]
}
